        {
          "name": "GET /recommendations (histórico)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/recommendations",
              "host": ["{{baseUrl}}"],
              "path": ["recommendations"]
            },
            "description": "Lista as últimas 50 recomendações do usuário (mais recentes primeiro)."
          }
        },
        {
          "name": "GET /recommendations/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/recommendations/{{recommendationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["recommendations", "{{recommendationId}}"]
            },
            "description": "Detalhe de uma recomendação específica do usuário."
          }
        },
        {
          "name": "POST /recommendations/items/:itemId/feedback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"feedback\": \"LIKED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recommendations/items/{{recommendationItemId}}/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["recommendations", "items", "{{recommendationItemId}}", "feedback"]
            },
            "description": "Registra feedback do usuário num item recomendado. Valores: LIKED | DISLIKED | PLAYED | SKIPPED."
          }
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "GET /stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/stats", "host": ["{{baseUrl}}"], "path": ["stats"] },
            "description": "Agregados da biblioteca do usuário: total de jogos, horas, contagem por status e top 10 gêneros."
          }
        }
      ]
    }
  ]
}
